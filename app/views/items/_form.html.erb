<%= form_with model: [@shop, @item],
      local: true,
      multipart: true,
      authenticity_token: form_authenticity_token,
      data: { turbo: false } do |f| %>
  <% if @item.errors.any? %>
    <div class="item-form-errors">
      <h2><%= @item.errors.count %>件のエラーがあります</h2>
      <ul>
        <% @item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="item-form-container">
    <% if local_assigns[:show_analyze_button] %>
      <div class="form-group">
        <%= f.label :image, "画像アップロード" %>
        <%= f.file_field :image %>
      </div>

      <div class="form-actions">
        <%= f.submit "AI解析して入力",
              formaction: analyze_shop_items_path(@shop),
              formmethod: "post" %>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :name, "商品名" %>
      <%= f.text_field :name %>
    </div>

    <div class="form-group">
      <%= f.label :brand, "ブランド名" %>
      <%= f.text_field :brand %>
    </div>

    <div class="form-group">
      <%= f.label :price, "参考価格" %>
      <%= f.number_field :price %>
    </div>

    <div class="form-group">
      <%= f.label :summary, "商品特徴" %>
      <%= f.text_area :summary %>
    </div>

    <div class="form-group">
      <%= f.label :source_platform, "SNS名" %>
      <%= f.text_field :source_platform %>
    </div>

    <div class="form-group">
      <%= f.label :source_author_name, "SNSアカウント" %>
      <%= f.text_field :source_author_name %>
    </div>

    <div class="form-group">
      <%= f.label :status, "ステータス" %>
      <%= f.select :status, Item.statuses.keys.map { |s| [t("enums.item.status.#{s}"), s] } %>
    </div>

    <% if local_assigns[:shop_candidates].present? %>
      <div class="form-group">
        <p>ショップ候補</p>
        <ul>
          <% local_assigns[:shop_candidates].each do |candidate| %>
            <li><%= candidate %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-actions">
      <%= f.submit @item.persisted? ? "更新する" : "登録する" %>
    </div>
  </div>
<% end %>
