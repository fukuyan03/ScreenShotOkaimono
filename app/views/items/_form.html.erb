<% label_classes = "text-sm font-medium text-stone-700" %>
<% field_classes = "mt-2 block w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm text-stone-900 shadow-sm outline-none transition focus:border-ochre-500 focus:ring-4 focus:ring-ochre-200" %>
<% auto_resize_field_classes = "#{field_classes} auto-resize resize-none overflow-hidden leading-7" %>
<% textarea_classes = "#{auto_resize_field_classes} min-h-28" %>
<% button_classes = "inline-flex items-center justify-center rounded-full bg-stone-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-stone-700" %>

<%= form_with model: [@shop, @item],
      local: true,
      multipart: true,
      authenticity_token: form_authenticity_token,
      data: { turbo: false } do |f| %>
  <% if @item.errors.any? %>
    <div class="mt-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-900">
      <h2 class="font-semibold"><%= @item.errors.count %>件のエラーがあります</h2>
      <ul class="mt-2">
        <% @item.errors.full_messages.each do |message| %>
          <li class="mt-1 first:mt-0"><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-8 rounded-[1.75rem] border border-stone-200 bg-white p-6 shadow-lg shadow-stone-200/70 sm:p-8">
    <% if local_assigns[:show_analyze_button] %>
      <div>
        <%= f.label :image, "画像アップロード", class: label_classes %>
        <%= f.file_field :image, class: "mt-2 block w-full rounded-2xl border border-dashed border-stone-300 bg-stone-50 px-4 py-5 text-sm text-stone-600 file:mr-4 file:rounded-full file:border-0 file:bg-stone-900 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:file:bg-stone-700" %>
      </div>

      <div class="mt-5">
        <%= f.submit "AI解析して入力",
              formaction: analyze_shop_items_path(@shop),
              formmethod: "post",
              class: "inline-flex items-center justify-center rounded-full border border-ochre-300 bg-ochre-50 px-5 py-3 text-sm font-semibold text-ochre-800 transition hover:bg-ochre-100" %>
      </div>
    <% end %>

    <div class="mt-8 grid gap-5 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <%= f.label :name, "商品名", class: label_classes %>
        <%= f.text_area :name, rows: 1, class: auto_resize_field_classes %>
      </div>

      <div>
        <%= f.label :brand, "ブランド名", class: label_classes %>
        <%= f.text_area :brand, rows: 1, class: auto_resize_field_classes %>
      </div>

      <div>
        <%= f.label :price, "参考価格", class: label_classes %>
        <%= f.number_field :price, class: field_classes %>
      </div>

      <div class="sm:col-span-2">
        <%= f.label :summary, "商品特徴", class: label_classes %>
        <%= f.text_area :summary, class: textarea_classes %>
      </div>

      <div>
        <%= f.label :source_platform, "SNS名", class: label_classes %>
        <%= f.text_area :source_platform, rows: 1, class: auto_resize_field_classes %>
      </div>

      <div>
        <%= f.label :source_author_name, "SNSアカウント", class: label_classes %>
        <%= f.text_area :source_author_name, rows: 1, class: auto_resize_field_classes %>
      </div>

      <div class="sm:col-span-2">
        <%= f.label :status, "ステータス", class: label_classes %>
        <%= f.select :status,
            Item.statuses.keys.map { |s| [t("enums.item.status.#{s}"), s] },
            {},
            class: field_classes %>
      </div>
    </div>

    <% if local_assigns[:shop_candidates].present? %>
      <div class="mt-6 rounded-2xl border border-ochre-200 bg-ochre-50 px-4 py-4">
        <p class="text-sm font-semibold text-ochre-800">ショップ候補</p>
        <ul class="mt-3 text-sm text-ochre-900">
          <% local_assigns[:shop_candidates].each do |candidate| %>
            <li class="mt-1 first:mt-0"><%= candidate %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mt-8">
      <%= f.submit @item.persisted? ? "更新する" : "登録する", class: button_classes %>
    </div>
  </div>
<% end %>
