<section class="mx-auto max-w-3xl py-4">
  <p class="text-sm font-semibold uppercase tracking-[0.24em] text-ochre-700"><%= @shop.name %></p>
  <h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-900">商品詳細</h1>

  <div class="mt-8 rounded-[1.75rem] border border-stone-200 bg-white p-6 shadow-lg shadow-stone-200/70 sm:p-8">
    <dl class="grid gap-6 sm:grid-cols-2">
      <div>
        <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-400">商品名</dt>
        <dd class="mt-2 text-base text-stone-900"><%= @item.name.presence || "未入力" %></dd>
      </div>
      <div>
        <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-400">ブランド名</dt>
        <dd class="mt-2 text-base text-stone-900"><%= @item.brand.presence || "未入力" %></dd>
      </div>
      <div>
        <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-400">参考価格</dt>
        <dd class="mt-2 text-base text-stone-900">
          <%= @item.price.present? ? "¥#{number_with_delimiter(@item.price)}" : "未入力" %>
        </dd>
      </div>
      <div>
        <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-400">ステータス</dt>
        <dd class="mt-2 text-base text-stone-900"><%= t("enums.item.status.#{@item.status}") %></dd>
      </div>
      <div class="sm:col-span-2">
        <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-400">商品特徴</dt>
        <dd class="mt-2 whitespace-pre-wrap text-base leading-7 text-stone-900"><%= @item.summary.presence || "未入力" %></dd>
      </div>
      <div>
        <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-400">ショップ</dt>
        <dd class="mt-2 text-base text-stone-900"><%= @shop.name %></dd>
      </div>
      <div>
        <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-400">SNS名</dt>
        <dd class="mt-2 text-base text-stone-900"><%= @item.source_platform.presence || "未入力" %></dd>
      </div>
      <div class="sm:col-span-2">
        <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-400">SNSアカウント名</dt>
        <dd class="mt-2 text-base text-stone-900"><%= @item.source_author_name.presence || "未入力" %></dd>
      </div>
    </dl>
  </div>

  <div class="mt-6 flex flex-col gap-3 sm:flex-row">
    <%= link_to "編集",
        edit_shop_item_path(@shop, @item),
        class: "inline-flex items-center justify-center rounded-full bg-stone-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-stone-700" %>
    <%= link_to "商品一覧に戻る",
        shop_items_path(@shop),
        class: "inline-flex items-center justify-center rounded-full border border-stone-300 px-5 py-3 text-sm font-semibold text-stone-700 transition hover:border-stone-400 hover:bg-white" %>
  </div>
</section>
