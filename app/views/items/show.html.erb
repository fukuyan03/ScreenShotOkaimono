<h1 class="item-show-title">商品詳細</h1>

<div class="item-show-card">
  <% if @item.image.attached? %>
    <div class="item-show-image">
      <%= image_tag @item.image, width: 220 %>
    </div>
  <% end %>

  <div class="item-show-body">
    <p><strong>商品名：</strong><%= @item.name.presence || "未入力" %></p>
    <p><strong>ブランド名：</strong><%= @item.brand.presence || "未入力" %></p>
    <p><strong>参考価格：</strong>
      <%= @item.price.present? ? "¥#{number_with_delimiter(@item.price)}" : "未入力" %>
    </p>
    <p><strong>商品特徴：</strong><%= @item.summary.presence || "未入力" %></p>
    <p><strong>ショップ：</strong><%= @shop.name %></p>
    <p><strong>ステータス：</strong><%= t("enums.item.status.#{@item.status}") %></p>
    <p><strong>SNS名：</strong><%= @item.source_platform.presence || "未入力" %></p>
    <p><strong>SNSアカウント名：</strong><%= @item.source_author_name.presence || "未入力" %></p>
  </div>
</div>

<div class="item-show-actions">
  <%= link_to "編集", edit_shop_item_path(@shop, @item), class: "item-edit-link" %>
  <%= link_to "商品一覧に戻る", shop_items_path(@shop), class: "item-back-link" %>
</div>