<% field_classes = "mt-2 block w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm text-stone-900 shadow-sm outline-none transition focus:border-ochre-500 focus:ring-4 focus:ring-ochre-200" %>

<section class="mx-auto max-w-md px-2 py-10 sm:px-0">
  <div class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-lg shadow-stone-200/70 sm:p-8">
    <h1 class="text-center text-3xl font-semibold tracking-tight text-stone-900">新しいパスワードを設定</h1>

    <% if @user.errors.any? %>
      <div class="mt-6 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-900">
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li class="mt-1 first:mt-0"><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: password_path(token: @token), method: :patch, local: true do |f| %>
      <div class="mt-8 space-y-5">
        <div>
          <%= f.label :password, "新しいパスワード", class: "text-sm font-medium text-stone-700" %>
          <%= f.password_field :password, class: field_classes, required: true, autofocus: true %>
        </div>

        <div>
          <%= f.label :password_confirmation, "新しいパスワード確認", class: "text-sm font-medium text-stone-700" %>
          <%= f.password_field :password_confirmation, class: field_classes, required: true %>
        </div>
      </div>

      <div class="mt-8">
        <%= f.submit "パスワードを更新する", class: "inline-flex w-full items-center justify-center rounded-full bg-stone-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-stone-700" %>
      </div>
    <% end %>
  </div>
</section>
