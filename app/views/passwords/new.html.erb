<% field_classes = "mt-2 block w-full rounded-2xl border border-stone-300 bg-white px-4 py-3 text-sm text-stone-900 shadow-sm outline-none transition focus:border-ochre-500 focus:ring-4 focus:ring-ochre-200" %>

<section class="mx-auto max-w-md px-2 py-10 sm:px-0">
  <div class="rounded-[2rem] border border-stone-200 bg-white p-6 shadow-lg shadow-stone-200/70 sm:p-8">
    <h1 class="text-center text-3xl font-semibold tracking-tight text-stone-900">パスワード再設定</h1>
    <p class="mt-4 text-sm leading-6 text-stone-600">
      登録済みのメールアドレスを入力すると、パスワード再設定用のURLを送信します。
    </p>

    <%= form_with url: password_path, local: true do |f| %>
      <div class="mt-8">
        <%= f.label :email, "メールアドレス", class: "text-sm font-medium text-stone-700" %>
        <%= f.email_field :email, class: field_classes, required: true, autofocus: true %>
      </div>

      <div class="mt-8">
        <%= f.submit "再設定メールを送信する", class: "inline-flex w-full items-center justify-center rounded-full bg-stone-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-stone-700" %>
      </div>
    <% end %>

    <div class="mt-6 text-center text-sm text-stone-600">
      <%= link_to "ログイン画面へ戻る", login_path, class: "font-medium text-ochre-700 transition hover:text-ochre-500" %>
    </div>
  </div>
</section>
