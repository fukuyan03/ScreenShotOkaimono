<header class="header">
  <div class="logo">
    <%= link_to "ScreenShot Okaimono", logged_in? ? shops_path : root_path %>
    <% if logged_in? %>
      <span class="header-user-name">| <%= current_user.name %>さんこんにちは</span>
    <% end %>
  </div>

  <div class="nav">
    <% if logged_in? %>
      <%= link_to "ログアウト", logout_path, data: { turbo_method: :delete } %>
    <% else %>
      <%= link_to "ログイン", login_path %>
      <%= link_to "新規登録", new_users_path %>
    <% end %>
  </div>
</header>