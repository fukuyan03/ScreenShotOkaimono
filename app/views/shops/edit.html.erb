<section class="mx-auto max-w-2xl py-4">
  <p class="text-sm font-semibold uppercase tracking-[0.24em] text-ochre-700">Edit Shop</p>
  <h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-900">ショップ編集</h1>

  <%= render "form", shop: @shop %>

  <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <%= button_to "削除",
        shop_path(@shop),
        method: :delete,
        data: { turbo_confirm: "削除しますか？" },
        class: "inline-flex items-center justify-center rounded-full border border-rose-300 px-5 py-3 text-sm font-semibold text-rose-700 transition hover:bg-rose-50" %>

    <%= link_to "一覧へ戻る", shops_path, class: "text-sm font-medium text-stone-600 transition hover:text-ochre-600" %>
  </div>
</section>
