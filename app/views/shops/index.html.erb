<h1 class="shops-title">ショップ一覧</h1>

<div class="shop-add-area">
  <%= link_to "＋ 追加", new_shop_path, class: "shop-add-button" %>
</div>

<% if @shops.any? %>
  <div class="shops-grid">

    <% @shops.each do |shop| %>

      <div class="shop-card">

        <div class="shop-card-name">
          <%= link_to shop.name, shop_items_path(shop) %>
        </div>

        <div class="shop-items-preview">

          <% shop.items.limit(5).each do |item| %>
            <div class="shop-item-row">
              □ <%= item.name %>
            </div>
          <% end %>

          <% if shop.items.count > 5 %>
            <div class="shop-item-more">
              …他 <%= shop.items.count - 5 %> 件
            </div>
          <% end %>

        </div>

      </div>

    <% end %>

  </div>
<% else %>
  <p class="shops-empty-message">まだお店が登録されていません</p>
<% end %>
