<section class="mx-auto max-w-2xl py-4">
  <p class="text-sm font-semibold uppercase tracking-[0.24em] text-ochre-700">Profile</p>
  <h1 class="mt-2 text-3xl font-semibold tracking-tight text-stone-900">ユーザー情報</h1>

  <div class="mt-8 rounded-[1.75rem] border border-stone-200 bg-white p-6 shadow-lg shadow-stone-200/70 sm:p-8">
    <dl class="grid gap-6 sm:grid-cols-2">
      <div>
        <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-400">名前</dt>
        <dd class="mt-2 text-base text-stone-900"><%= @user.name %></dd>
      </div>
      <div>
        <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-400">Email</dt>
        <dd class="mt-2 text-base text-stone-900"><%= @user.email %></dd>
      </div>
    </dl>
  </div>
</section>
